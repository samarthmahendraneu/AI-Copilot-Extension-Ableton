# ── OpenAI ───────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Ableton Extensions SDK ───────────────────────────────────────────────────
# Path to the ExtensionHostNodeModule.node binary inside your Live installation.
#
# macOS (default path):
EXTENSION_HOST_PATH=/Applications/Ableton Live 12 Suite.app/Contents/Helpers/ExtensionHost/ExtensionHostNodeModule.node
#
# macOS (Beta build — change if your app name differs):
# EXTENSION_HOST_PATH=/Applications/Ableton Live 12 Beta.app/Contents/Helpers/ExtensionHost/ExtensionHostNodeModule.node
#
# Windows (typical path — adjust drive/username as needed):
# EXTENSION_HOST_PATH=C:\ProgramData\Ableton\Live 12 Suite\Program\ExtensionHost\ExtensionHostNodeModule.node
